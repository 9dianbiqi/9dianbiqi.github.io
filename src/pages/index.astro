---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import HomeHero from '../components/HomeHero.astro';
import ImageStrip from '../components/ImageStrip.astro';
import LearningPath from '../components/LearningPath.astro';
import { home } from '../site.config';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = posts[0];
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
---

<BaseLayout>
  <HomeHero hero={home.hero} />
  <FeaturedPost
    post={featuredPost}
    eyebrow={home.featured.eyebrow}
    title={home.featured.title}
    formattedDate={formatDate(featuredPost.data.pubDate)}
  />
  <LearningPath learningPath={home.learningPath} />
  <ImageStrip imageStrip={home.imageStrip} />
</BaseLayout>
