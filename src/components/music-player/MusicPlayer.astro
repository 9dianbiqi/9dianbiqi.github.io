---
import { musicPlayerConfig } from '../../music.config';
import { validateQishuiTracks } from './validation';

validateQishuiTracks(musicPlayerConfig.qishuiTracks);
---

<music-player data-config={JSON.stringify(musicPlayerConfig)}>
  <svg slot="icon-play" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <path fill="currentColor" d="M8 5v14l11-7z"></path>
  </svg>
  <svg slot="icon-pause" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <path fill="currentColor" d="M6 5h4v14H6zm8 0h4v14h-4z"></path>
  </svg>
  <svg slot="icon-previous" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <path fill="currentColor" d="M6 6h2v12H6zm3 6 9 6V6z"></path>
  </svg>
  <svg slot="icon-next" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <path fill="currentColor" d="m6 6 9 6-9 6zm10 0h2v12h-2z"></path>
  </svg>
</music-player>

<script>
  import './music-player';
</script>
