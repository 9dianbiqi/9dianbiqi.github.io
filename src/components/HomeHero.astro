---
import { Image } from 'astro:assets';

interface Action {
  label: string;
  href: string;
  variant: string;
}

interface Props {
  hero: {
    eyebrow: string;
    title: string;
    description: string;
    image: ImageMetadata;
    imageAlt: string;
    actions: Action[];
  };
  latestPostHref: string;
}

const { hero, latestPostHref } = Astro.props;
const actions = hero.actions.map((action, index) =>
  index === 0 ? { ...action, href: latestPostHref } : action,
);
---

<section class="hero-section reveal">
  <div class="hero-copy">
    <p class="eyebrow">{hero.eyebrow}</p>
    <h1>{hero.title}</h1>
    <p class="hero-lede">{hero.description}</p>
    <div class="hero-actions" aria-label="快捷入口">
      {
        actions.map((action) => (
          <a class={`button ${action.variant}`} href={action.href}>
            {action.label}
          </a>
        ))
      }
    </div>
  </div>
  <figure class="hero-media">
    <Image
      src={hero.image}
      alt={hero.imageAlt}
      widths={[640, 960, 1280, 1536]}
      sizes="(max-width: 900px) calc(100vw - 28px), 48vw"
      loading="eager"
      decoding="async"
    />
  </figure>
</section>
