---
import { Image } from 'astro:assets';

interface Action {
  label: string;
  href: string;
  variant: string;
}

interface Props {
  hero: {
    eyebrow: string;
    title: string;
    description: string;
    image: ImageMetadata;
    imageAlt: string;
    video?: {
      src: string;
      poster: string;
      type?: string;
    };
    actions: Action[];
  };
  latestPostHref: string;
}

const { hero, latestPostHref } = Astro.props;
const actions = hero.actions.map((action, index) =>
  index === 0 ? { ...action, href: latestPostHref } : action,
);
---

<section class:list={['hero-section', hero.video && 'hero-video-section', 'reveal']}>
  {
    hero.video && (
      <div class="hero-video-background" aria-hidden="true">
        <video autoplay muted loop playsinline poster={hero.video.poster}>
          <source src={hero.video.src} type={hero.video.type ?? 'video/mp4'} />
        </video>
      </div>
    )
  }
  <div class="hero-copy">
    <p class="eyebrow">{hero.eyebrow}</p>
    <h1>{hero.title}</h1>
    <p class="hero-lede">{hero.description}</p>
    <div class="hero-actions" aria-label="快捷入口">
      {
        actions.map((action) => (
          <a class={`button ${action.variant}`} href={action.href}>
            {action.label}
          </a>
        ))
      }
    </div>
  </div>
  {
    !hero.video && (
      <figure class="hero-media">
        <Image
          src={hero.image}
          alt={hero.imageAlt}
          widths={[640, 960, 1280, 1536]}
          sizes="(max-width: 900px) calc(100vw - 28px), 48vw"
          loading="eager"
          decoding="async"
        />
      </figure>
    )
  }
</section>
